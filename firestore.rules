// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: lessons
// Document ID: auto-generated
// Fields:
//   - title: string (required, 1-100 chars) - The name of the lesson.
//   - creatorId: string (required) - The UID of the user who created the lesson.
//   - words: list (required, max 50 items) - The list of words in the lesson.
//     - word: string (required, 1-50 chars)
//     - image: string (required, valid URL)
//   - createdAt: timestamp (optional)
//   - updatedAt: timestamp (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "banmetrongtoi@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }

    function isValidWord(wordData) {
      return wordData is map &&
        wordData.word is string && wordData.word.size() > 0 && wordData.word.size() <= 50 &&
        isValidUrl(wordData.image);
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['title', 'words', 'creatorId']) &&
        data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
        data.words is list && data.words.size() <= 50 &&
        data.words.all(word, isValidWord(word)) &&
        data.creatorId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /lessons/{lessonId} {
      // Allow everyone to read lessons (publicly accessible for kids to learn)
      allow read: if true;

      // Only authenticated users can create lessons
      allow create: if isAuthenticated() && isValidLesson(request.resource.data) &&
        (request.resource.data.creatorId == request.auth.uid || isAdmin());

      // Only owners or admins can update or delete lessons
      allow update: if isAuthenticated() && isValidLesson(request.resource.data) &&
        (isOwner(resource.data.creatorId) || isAdmin()) &&
        request.resource.data.creatorId == resource.data.creatorId;

      allow delete: if isAuthenticated() && (isOwner(resource.data.creatorId) || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
