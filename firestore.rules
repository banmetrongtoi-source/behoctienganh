// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: lessons
// Document ID: auto-generated
// Fields:
//   - title: string (required, 1-100 chars)
//   - creatorId: string (required)
//   - words: list (required, max 50 items)
//     - word: string (required, 1-50 chars)
//     - image: string (required, valid URL)
//   - createdAt: timestamp (optional)
//   - updatedAt: timestamp (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['title', 'words', 'creatorId']) &&
        data.title is string && data.title.size() > 0 &&
        data.words is list && data.words.size() > 0 &&
        data.creatorId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /lessons/{lessonId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
